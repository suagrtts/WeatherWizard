<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:paddingBottom="80dp"
    android:clipToPadding="false"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="25dp"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="10dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Smart Calendar"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white" />
            <TextView
                android:id="@+id/tvCalendarMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/azure_light" />
        </LinearLayout>

        <!-- Legend -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginEnd="16dp">
                <View android:layout_width="10dp" android:layout_height="10dp"
                    android:background="@drawable/dot_best" android:layout_marginEnd="5dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Best day" android:textSize="11sp" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginEnd="16dp">
                <View android:layout_width="10dp" android:layout_height="10dp"
                    android:background="@drawable/dot_moderate" android:layout_marginEnd="5dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Moderate" android:textSize="11sp" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <View android:layout_width="10dp" android:layout_height="10dp"
                    android:background="@drawable/dot_avoid" android:layout_marginEnd="5dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Avoid" android:textSize="11sp" android:textColor="@color/text_muted"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Day-of-week header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="4dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="S" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="M" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="T" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="W" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="T" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="F" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="S" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:gravity="center"/>
        </LinearLayout>

        <!-- Dynamic calendar grid container -->
        <LinearLayout
            android:id="@+id/llCalendarGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginBottom="14dp" />

        <!-- Forecast day detail card -->
        <LinearLayout
            android:id="@+id/llCalDetailCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_best"
            android:padding="16dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvCalDetailDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/green_good"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvCalDetailRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/green_good"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tvCalDetailTemp"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text=""
                    android:textSize="12sp" android:textColor="@color/white"
                    android:background="@drawable/bg_chip" android:padding="8dp"
                    android:gravity="center" android:layout_marginEnd="6dp"/>
                <TextView
                    android:id="@+id/tvCalDetailRain"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text=""
                    android:textSize="12sp" android:textColor="@color/white"
                    android:background="@drawable/bg_chip" android:padding="8dp"
                    android:gravity="center" android:layout_marginEnd="6dp"/>
                <TextView
                    android:id="@+id/tvCalDetailReason"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text=""
                    android:textSize="11sp" android:textColor="@color/white"
                    android:background="@drawable/bg_chip" android:padding="8dp"
                    android:gravity="center"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Best day summary (shown when detail card not selected) -->
        <LinearLayout
            android:id="@+id/llCalBestDay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_best"
            android:padding="16dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="12dp">
            <TextView
                android:id="@+id/tvCalBestDayLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 Loading best day…"
                android:textSize="13sp"
                android:textColor="@color/green_good"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvCalBestDayReason"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Export button -->
        <Button
            android:id="@+id/btnExportCalendar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="📅  Export to Calendar"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="@color/azure"
            android:stateListAnimator="@null"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            style="@style/Widget.MaterialComponents.Button" />

    </LinearLayout>
</ScrollView>
