<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="10dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Smart Calendar"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="March 2026"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/azure_light" />
        </LinearLayout>

        <!-- Legend -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginEnd="16dp">
                <View android:layout_width="10dp" android:layout_height="10dp"
                    android:background="@drawable/dot_best" android:layout_marginEnd="5dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Best day" android:textSize="11sp" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginEnd="16dp">
                <View android:layout_width="10dp" android:layout_height="10dp"
                    android:background="@drawable/dot_moderate" android:layout_marginEnd="5dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Moderate" android:textSize="11sp" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <View android:layout_width="10dp" android:layout_height="10dp"
                    android:background="@drawable/dot_avoid" android:layout_marginEnd="5dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Avoid" android:textSize="11sp" android:textColor="@color/text_muted"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Day-of-week header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="4dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="S" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="M" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="T" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="W" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="T" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="F" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="S" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:gravity="center"/>
        </LinearLayout>

        <!-- Calendar rows -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingStart="10dp" android:paddingEnd="10dp"
            android:layout_marginBottom="14dp">

            <!-- Row 1: 1–7 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="4dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_moderate" android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌤" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="1" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_avoid" android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⛈" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="2" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_avoid" android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌧" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="3" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_moderate" android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⛅" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="4" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_best" android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="☀️" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="5" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_best" android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="☀️" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="6" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_best">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="☀️" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="7" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2: 8–14 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="4dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_moderate" android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌤" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="8" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_avoid" android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌧" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="9" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_avoid" android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⛈" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="10" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_avoid" android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌧" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="11" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_moderate" android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⛅" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="12" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_best" android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="☀️" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="13" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_best">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="☀️" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="14" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Row 3: 15–21 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_best" android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="☀️" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="15" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_moderate" android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌤" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="16" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_moderate" android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⛅" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="17" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_avoid" android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌧" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="18" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_avoid" android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⛈" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="19" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_moderate" android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌤" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="20" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:gravity="center" android:padding="5dp"
                    android:background="@drawable/bg_cal_best">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="☀️" android:textSize="11sp" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="21" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Day detail card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_best"
            android:padding="16dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 Sunday, March 6"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/green_good"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Best Day to Go Out"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/green_good"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="🌡 High 32°C"
                    android:textSize="12sp" android:textColor="@color/white"
                    android:background="@drawable/bg_chip" android:padding="8dp"
                    android:gravity="center" android:layout_marginEnd="6dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="💧 8% rain"
                    android:textSize="12sp" android:textColor="@color/white"
                    android:background="@drawable/bg_chip" android:padding="8dp"
                    android:gravity="center" android:layout_marginEnd="6dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="💨 12 km/h"
                    android:textSize="12sp" android:textColor="@color/white"
                    android:background="@drawable/bg_chip" android:padding="8dp"
                    android:gravity="center"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Export button -->
        <Button
            android:id="@+id/btnExportCalendar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="📅  Export to Calendar"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="@color/azure"
            android:stateListAnimator="@null"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            style="@style/Widget.MaterialComponents.Button" />

    </LinearLayout>
</ScrollView>
