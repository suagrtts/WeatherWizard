<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:paddingBottom="80dp"
    android:clipToPadding="false"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="25dp"
        android:paddingBottom="24dp">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Current Location"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted" />
                <TextView
                    android:id="@+id/tvHomeCity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading…"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvNotifBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="🔔"
                android:gravity="center"
                android:textSize="18sp"
                android:background="@drawable/bg_icon_btn" />
        </LinearLayout>

        <!-- Weather hero -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tvHomeIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⛅"
                android:textSize="72sp" />

            <TextView
                android:id="@+id/tvHomeTemp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="68sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/tvHomeDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading…"
                android:textSize="16sp"
                android:textColor="@color/text_muted"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvHomeFeelsHumidity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Feels like --° · Humidity --%"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Stat pills -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginBottom="20dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_glass_card" android:padding="12dp"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💧" android:textSize="18sp" android:gravity="center" />
                <TextView
                    android:id="@+id/tvHomeHumidityVal"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--%"
                    android:textSize="14sp" android:textStyle="bold"
                    android:textColor="@color/white" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="HUMIDITY" android:textSize="9sp"
                    android:textColor="@color/text_muted" android:gravity="center" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_glass_card" android:padding="12dp"
                android:layout_marginStart="6dp" android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💨" android:textSize="18sp" android:gravity="center" />
                <TextView
                    android:id="@+id/tvHomeWindVal"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="-- km/h"
                    android:textSize="14sp" android:textStyle="bold"
                    android:textColor="@color/white" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="WIND" android:textSize="9sp"
                    android:textColor="@color/text_muted" android:gravity="center" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_glass_card" android:padding="12dp"
                android:layout_marginStart="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="👁" android:textSize="18sp" android:gravity="center" />
                <TextView
                    android:id="@+id/tvHomeVisibilityVal"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="-- km"
                    android:textSize="14sp" android:textStyle="bold"
                    android:textColor="@color/white" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="VISIBILITY" android:textSize="9sp"
                    android:textColor="@color/text_muted" android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- Hourly header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HOURLY FORECAST"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/text_muted"
            android:letterSpacing="0.1"
            android:paddingStart="16dp"
            android:layout_marginBottom="10dp" />

        <!-- Hourly scroll -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:clipToPadding="false"
            android:scrollbars="none"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:id="@+id/llHomeHourly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <!-- 5-Day header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="16dp" android:paddingEnd="16dp" android:layout_marginBottom="10dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="5-DAY FORECAST"
                android:textSize="11sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:letterSpacing="0.1" />
            <TextView
                android:id="@+id/tvSeeForecast"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Details →"
                android:textSize="12sp"
                android:textColor="@color/azure_light"
                android:padding="4dp" />
        </LinearLayout>

        <!-- Daily rows container -->
        <LinearLayout
            android:id="@+id/llHomeDaily"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp" />

    </LinearLayout>
</ScrollView>
