<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:paddingBottom="80dp"
    android:clipToPadding="false"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="25dp"
        android:paddingBottom="24dp">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Current Location"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cebu City, PH"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvNotifBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="🔔"
                android:gravity="center"
                android:textSize="18sp"
                android:background="@drawable/bg_icon_btn" />
        </LinearLayout>

        <!-- Weather hero -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⛅"
                android:textSize="72sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="28°"
                android:textSize="68sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Partly Cloudy"
                android:textSize="16sp"
                android:textColor="@color/text_muted"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Feels like 31° · Humidity 78%"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Stat pills -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginBottom="20dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_glass_card" android:padding="12dp"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💧" android:textSize="18sp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="78%" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="@color/white" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="HUMIDITY" android:textSize="9sp"
                    android:textColor="@color/text_muted" android:gravity="center" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_glass_card" android:padding="12dp"
                android:layout_marginStart="6dp" android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💨" android:textSize="18sp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="18 km/h" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="@color/white" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="WIND" android:textSize="9sp"
                    android:textColor="@color/text_muted" android:gravity="center" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_glass_card" android:padding="12dp"
                android:layout_marginStart="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="👁" android:textSize="18sp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="10 km" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="@color/white" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="VISIBILITY" android:textSize="9sp"
                    android:textColor="@color/text_muted" android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- Hourly header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HOURLY FORECAST"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/text_muted"
            android:letterSpacing="0.1"
            android:paddingStart="16dp"
            android:layout_marginBottom="10dp" />

        <!-- Hourly scroll -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:clipToPadding="false"
            android:scrollbars="none"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Now -->
                <LinearLayout android:layout_width="62dp" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="10dp"
                    android:background="@drawable/bg_hourly_now" android:layout_marginEnd="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Now" android:textSize="10sp" android:textColor="@color/white" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⛅" android:textSize="20sp" android:gravity="center"
                        android:layout_marginTop="4dp" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="28°" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="5%" android:textSize="10sp" android:textColor="@color/rain_color" android:gravity="center"/>
                </LinearLayout>

                <!-- 2 PM -->
                <LinearLayout android:layout_width="62dp" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="10dp"
                    android:background="@drawable/bg_glass_card" android:layout_marginEnd="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="2 PM" android:textSize="10sp" android:textColor="@color/text_muted" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="☀️" android:textSize="20sp" android:gravity="center"
                        android:layout_marginTop="4dp" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="30°" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="2%" android:textSize="10sp" android:textColor="@color/rain_color" android:gravity="center"/>
                </LinearLayout>

                <!-- 4 PM -->
                <LinearLayout android:layout_width="62dp" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="10dp"
                    android:background="@drawable/bg_glass_card" android:layout_marginEnd="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="4 PM" android:textSize="10sp" android:textColor="@color/text_muted" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌤" android:textSize="20sp" android:gravity="center"
                        android:layout_marginTop="4dp" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="29°" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="8%" android:textSize="10sp" android:textColor="@color/rain_color" android:gravity="center"/>
                </LinearLayout>

                <!-- 6 PM -->
                <LinearLayout android:layout_width="62dp" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="10dp"
                    android:background="@drawable/bg_glass_card" android:layout_marginEnd="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="6 PM" android:textSize="10sp" android:textColor="@color/text_muted" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌧" android:textSize="20sp" android:gravity="center"
                        android:layout_marginTop="4dp" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="26°" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="65%" android:textSize="10sp" android:textColor="@color/rain_color" android:gravity="center"/>
                </LinearLayout>

                <!-- 8 PM -->
                <LinearLayout android:layout_width="62dp" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="10dp"
                    android:background="@drawable/bg_glass_card">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="8 PM" android:textSize="10sp" android:textColor="@color/text_muted" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⛈" android:textSize="20sp" android:gravity="center"
                        android:layout_marginTop="4dp" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="24°" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="80%" android:textSize="10sp" android:textColor="@color/rain_color" android:gravity="center"/>
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- 7-Day header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="16dp" android:paddingEnd="16dp" android:layout_marginBottom="10dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="7-DAY FORECAST"
                android:textSize="11sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:letterSpacing="0.1" />
            <TextView
                android:id="@+id/tvSeeForecast"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Details →"
                android:textSize="12sp"
                android:textColor="@color/azure_light"
                android:padding="4dp" />
        </LinearLayout>

        <!-- Daily rows -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <!-- Today -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="10dp" android:layout_marginBottom="6dp"
                android:background="@drawable/bg_today_row">
                <TextView android:layout_width="44dp" android:layout_height="wrap_content"
                    android:text="Today" android:textSize="13sp" android:textColor="@color/white"/>
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="⛅" android:textSize="18sp" android:gravity="center" android:layout_marginEnd="10dp"/>
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1"
                    android:background="@drawable/bg_temp_bar" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="24° / 30°" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <!-- Tue -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="10dp" android:layout_marginBottom="6dp"
                android:background="@drawable/bg_glass_card">
                <TextView android:layout_width="44dp" android:layout_height="wrap_content"
                    android:text="Tue" android:textSize="13sp" android:textColor="@color/white"/>
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="🌧" android:textSize="18sp" android:gravity="center" android:layout_marginEnd="10dp"/>
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1"
                    android:background="@drawable/bg_temp_bar" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="22° / 27°" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <!-- Wed -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="10dp" android:layout_marginBottom="6dp"
                android:background="@drawable/bg_glass_card">
                <TextView android:layout_width="44dp" android:layout_height="wrap_content"
                    android:text="Wed" android:textSize="13sp" android:textColor="@color/white"/>
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="⛈" android:textSize="18sp" android:gravity="center" android:layout_marginEnd="10dp"/>
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1"
                    android:background="@drawable/bg_temp_bar" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="21° / 25°" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <!-- Thu -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="10dp" android:layout_marginBottom="6dp"
                android:background="@drawable/bg_glass_card">
                <TextView android:layout_width="44dp" android:layout_height="wrap_content"
                    android:text="Thu" android:textSize="13sp" android:textColor="@color/white"/>
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="☀️" android:textSize="18sp" android:gravity="center" android:layout_marginEnd="10dp"/>
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1"
                    android:background="@drawable/bg_temp_bar" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="26° / 33°" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <!-- Fri -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="10dp"
                android:background="@drawable/bg_glass_card">
                <TextView android:layout_width="44dp" android:layout_height="wrap_content"
                    android:text="Fri" android:textSize="13sp" android:textColor="@color/white"/>
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="☀️" android:textSize="18sp" android:gravity="center" android:layout_marginEnd="10dp"/>
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1"
                    android:background="@drawable/bg_temp_bar" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="27° / 34°" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_muted"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
