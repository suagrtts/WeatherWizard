<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:overScrollMode="never"
    android:paddingBottom="80dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="25dp"
        android:paddingBottom="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:paddingStart="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Avatar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:text="🧑"
                android:textSize="36sp"
                android:gravity="center"
                android:background="@drawable/bg_avatar_ring"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/tvProfileEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Guest"
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:layout_marginTop="3dp" />

            <TextView
                android:id="@+id/tvProfileLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location unavailable"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Saved Locations header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SAVED LOCATIONS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/text_muted"
                android:letterSpacing="0.1"/>
            <TextView
                android:id="@+id/tvUseGps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:text="📍 GPS"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"/>
            <TextView
                android:id="@+id/tvAddLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:text="+ Add"
                android:textColor="@color/azure_light"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Dynamic saved locations container -->
        <LinearLayout
            android:id="@+id/llSavedLocations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginBottom="20dp"/>

        <!-- Preferences header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PREFERENCES"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/text_muted"
            android:letterSpacing="0.1"
            android:paddingStart="16dp"
            android:layout_marginBottom="8dp"/>

        <!-- Settings list -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp">

            <!-- Temp Unit -->
            <LinearLayout
                android:id="@+id/rowTempUnit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">
                <TextView android:layout_width="34dp" android:layout_height="34dp"
                    android:text="🌡" android:gravity="center" android:textSize="18sp"
                    android:background="@drawable/bg_settings_icon_blue"
                    android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Temperature Unit"
                    android:textSize="14sp" android:textColor="@color/white"/>
                <TextView
                    android:id="@+id/tvTempUnitValue"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Celsius" android:textSize="13sp" android:textColor="@color/text_muted"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text=" ›" android:textSize="18sp" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginStart="14dp"/>

            <!-- Time Format -->
            <LinearLayout
                android:id="@+id/rowTimeFormat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">
                <TextView android:layout_width="34dp" android:layout_height="34dp"
                    android:text="🕐" android:gravity="center" android:textSize="18sp"
                    android:background="@drawable/bg_settings_icon_cyan"
                    android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Time Format"
                    android:textSize="14sp" android:textColor="@color/white"/>
                <TextView
                    android:id="@+id/tvTimeFormatValue"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="12-hour" android:textSize="13sp" android:textColor="@color/text_muted"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text=" ›" android:textSize="18sp" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginStart="14dp"/>

            <!-- Activity Type -->
            <LinearLayout
                android:id="@+id/rowActivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">
                <TextView android:layout_width="34dp" android:layout_height="34dp"
                    android:text="🏃" android:gravity="center" android:textSize="18sp"
                    android:background="@drawable/bg_settings_icon_green"
                    android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Activity Type"
                    android:textSize="14sp" android:textColor="@color/white"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Outdoor" android:textSize="13sp" android:textColor="@color/text_muted"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text=" ›" android:textSize="18sp" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginStart="14dp"/>

            <!-- Change Password -->
            <LinearLayout
                android:id="@+id/rowChangePassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">
                <TextView android:layout_width="34dp" android:layout_height="34dp"
                    android:text="🔒" android:gravity="center" android:textSize="18sp"
                    android:background="@drawable/bg_settings_icon_amber"
                    android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Change Password"
                    android:textSize="14sp" android:textColor="@color/white"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="18sp" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginStart="14dp"/>

            <!-- Log Out -->
            <LinearLayout
                android:id="@+id/rowLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">
                <TextView android:layout_width="34dp" android:layout_height="34dp"
                    android:text="🚪" android:gravity="center" android:textSize="18sp"
                    android:background="@drawable/bg_settings_icon_red"
                    android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Log Out"
                    android:textSize="14sp" android:textColor="@color/red_bad"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="18sp" android:textColor="@color/text_muted"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
