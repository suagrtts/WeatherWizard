<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="25dp"
        android:paddingBottom="24dp">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="16dp">
            <TextView
                android:id="@+id/tvForecastBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textSize="22sp"
                android:textColor="@color/white"
                android:padding="4dp"
                android:paddingEnd="12dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7-Day Forecast"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white" />
        </LinearLayout>

        <!-- UV Index card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_uv"
            android:padding="16dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="UV INDEX" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:letterSpacing="0.08"
                android:layout_marginBottom="10dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="☀️" android:textSize="40sp" android:layout_marginEnd="16dp" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="7 — High" android:textSize="16sp" android:textStyle="bold"
                        android:textColor="@color/sun_color" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SPF 50+ recommended. Seek shade 10AM–4PM."
                        android:textSize="12sp" android:textColor="@color/text_muted"
                        android:layout_marginTop="4dp" android:lineSpacingExtra="2dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Sun card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SUN" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌅" android:textSize="28sp" android:gravity="center" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SUNRISE" android:textSize="10sp" android:textColor="@color/text_muted"
                        android:gravity="center" android:layout_marginTop="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="5:43 AM" android:textSize="16sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="20sp" android:textColor="@color/text_muted" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌇" android:textSize="28sp" android:gravity="center" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SUNSET" android:textSize="10sp" android:textColor="@color/text_muted"
                        android:gravity="center" android:layout_marginTop="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="6:12 PM" android:textSize="16sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- AQI card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_aqi"
            android:padding="16dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="AIR QUALITY" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:letterSpacing="0.08"
                android:layout_marginBottom="10dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="AQI 42" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/green_good"
                    android:background="@drawable/bg_badge_aqi"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:paddingTop="6dp" android:paddingBottom="6dp"
                    android:layout_marginEnd="14dp" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Good" android:textSize="15sp" android:textStyle="bold"
                        android:textColor="@color/white" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Air quality is satisfactory."
                        android:textSize="11sp" android:textColor="@color/text_muted"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Weekly section -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="WEEKLY BREAKDOWN" android:textSize="11sp" android:textStyle="bold"
            android:textColor="@color/text_muted" android:letterSpacing="0.1"
            android:paddingStart="16dp" android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="10dp" android:layout_marginBottom="6dp"
                android:background="@drawable/bg_today_row">
                <TextView android:layout_width="44dp" android:layout_height="wrap_content"
                    android:text="Today" android:textSize="13sp" android:textColor="@color/white"/>
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="⛅" android:textSize="18sp" android:gravity="center" android:layout_marginEnd="10dp"/>
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1"
                    android:background="@drawable/bg_temp_bar" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="24–30°" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="10dp" android:layout_marginBottom="6dp"
                android:background="@drawable/bg_glass_card">
                <TextView android:layout_width="44dp" android:layout_height="wrap_content"
                    android:text="Tue" android:textSize="13sp" android:textColor="@color/white"/>
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="🌧" android:textSize="18sp" android:gravity="center" android:layout_marginEnd="10dp"/>
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1"
                    android:background="@drawable/bg_temp_bar" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="22–27°" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="10dp" android:layout_marginBottom="6dp"
                android:background="@drawable/bg_glass_card">
                <TextView android:layout_width="44dp" android:layout_height="wrap_content"
                    android:text="Wed" android:textSize="13sp" android:textColor="@color/white"/>
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="⛈" android:textSize="18sp" android:gravity="center" android:layout_marginEnd="10dp"/>
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1"
                    android:background="@drawable/bg_temp_bar" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="21–25°" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="10dp" android:layout_marginBottom="6dp"
                android:background="@drawable/bg_glass_card">
                <TextView android:layout_width="44dp" android:layout_height="wrap_content"
                    android:text="Thu" android:textSize="13sp" android:textColor="@color/white"/>
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="☀️" android:textSize="18sp" android:gravity="center" android:layout_marginEnd="10dp"/>
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1"
                    android:background="@drawable/bg_temp_bar" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="26–33°" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="10dp" android:layout_marginBottom="6dp"
                android:background="@drawable/bg_glass_card">
                <TextView android:layout_width="44dp" android:layout_height="wrap_content"
                    android:text="Fri" android:textSize="13sp" android:textColor="@color/white"/>
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="☀️" android:textSize="18sp" android:gravity="center" android:layout_marginEnd="10dp"/>
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1"
                    android:background="@drawable/bg_temp_bar" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="27–34°" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="10dp" android:layout_marginBottom="6dp"
                android:background="@drawable/bg_glass_card">
                <TextView android:layout_width="44dp" android:layout_height="wrap_content"
                    android:text="Sat" android:textSize="13sp" android:textColor="@color/white"/>
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="🌤" android:textSize="18sp" android:gravity="center" android:layout_marginEnd="10dp"/>
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1"
                    android:background="@drawable/bg_temp_bar" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="25–32°" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="10dp"
                android:background="@drawable/bg_glass_card">
                <TextView android:layout_width="44dp" android:layout_height="wrap_content"
                    android:text="Sun" android:textSize="13sp" android:textColor="@color/white"/>
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="⛅" android:textSize="18sp" android:gravity="center" android:layout_marginEnd="10dp"/>
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1"
                    android:background="@drawable/bg_temp_bar" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="24–29°" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_muted"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
