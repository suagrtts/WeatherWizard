<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- Loading state -->
    <ProgressBar
        android:id="@+id/progressForecast"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/azure"
        android:visibility="visible" />

    <!-- Error / offline state -->
    <LinearLayout
        android:id="@+id/layoutForecastError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌐"
            android:textSize="48sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No forecast available"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Check your connection and try again."
            android:textSize="13sp"
            android:textColor="@color/text_muted"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/btnForecastRetry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Retry"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/bg_badge_aqi"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp" />
    </LinearLayout>

    <!-- Main content scroll (hidden until data loads) -->
    <ScrollView
        android:id="@+id/scrollForecastContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="25dp"
            android:paddingBottom="24dp">

            <!-- Top bar: back + title + temp unit toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvForecastBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="←"
                    android:textSize="22sp"
                    android:textColor="@color/white"
                    android:padding="4dp"
                    android:paddingEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5-Day Forecast"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />
                    <TextView
                        android:id="@+id/tvForecastCity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="12sp"
                        android:textColor="@color/text_muted" />
                </LinearLayout>

                <!-- Temperature unit toggle button -->
                <TextView
                    android:id="@+id/tvForecastTempToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Switch to °F"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/azure_light"
                    android:background="@drawable/bg_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" />
            </LinearLayout>

            <!-- UV Index card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_uv"
                android:padding="16dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="UV INDEX" android:textSize="10sp" android:textStyle="bold"
                    android:textColor="@color/text_muted" android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="☀️" android:textSize="40sp" android:layout_marginEnd="16dp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvForecastUvValue"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="— Loading"
                            android:textSize="16sp" android:textStyle="bold"
                            android:textColor="@color/sun_color" />
                        <TextView
                            android:id="@+id/tvForecastUvTip"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Fetching UV data…"
                            android:textSize="12sp" android:textColor="@color/text_muted"
                            android:layout_marginTop="4dp" android:lineSpacingExtra="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Sun card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SUN" android:textSize="10sp" android:textStyle="bold"
                    android:textColor="@color/text_muted" android:letterSpacing="0.08"
                    android:layout_marginBottom="12dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🌅" android:textSize="28sp" android:gravity="center" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="SUNRISE" android:textSize="10sp" android:textColor="@color/text_muted"
                            android:gravity="center" android:layout_marginTop="4dp" />
                        <TextView
                            android:id="@+id/tvForecastSunrise"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="--:--"
                            android:textSize="16sp" android:textStyle="bold"
                            android:textColor="@color/white" android:gravity="center" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="20sp" android:textColor="@color/text_muted" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🌇" android:textSize="28sp" android:gravity="center" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="SUNSET" android:textSize="10sp" android:textColor="@color/text_muted"
                            android:gravity="center" android:layout_marginTop="4dp" />
                        <TextView
                            android:id="@+id/tvForecastSunset"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="--:--"
                            android:textSize="16sp" android:textStyle="bold"
                            android:textColor="@color/white" android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- AQI card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_aqi"
                android:padding="16dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:layout_marginBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="AIR QUALITY" android:textSize="10sp" android:textStyle="bold"
                    android:textColor="@color/text_muted" android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tvForecastAqiBadge"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="AQI —"
                        android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/green_good"
                        android:background="@drawable/bg_badge_aqi"
                        android:paddingStart="12dp" android:paddingEnd="12dp"
                        android:paddingTop="6dp" android:paddingBottom="6dp"
                        android:layout_marginEnd="14dp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvForecastAqiLabel"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Loading…"
                            android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/white" />
                        <TextView
                            android:id="@+id/tvForecastAqiDesc"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Fetching air quality…"
                            android:textSize="11sp" android:textColor="@color/text_muted"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Weekly section -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="WEEKLY BREAKDOWN" android:textSize="11sp" android:textStyle="bold"
                android:textColor="@color/text_muted" android:letterSpacing="0.1"
                android:paddingStart="16dp" android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/llForecastWeekly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

        </LinearLayout>
    </ScrollView>

</FrameLayout>
